# --- Obrigatório ---
OPENAI_API_KEY=sua_chave_api_aqui

# --- LLM (opcional, valores padrão abaixo) ---
LLM_MODEL=gpt-3.5-turbo
LLM_TEMPERATURE=0.3
LLM_MAX_TOKENS=1500

# --- Vision (opcional) ---
VISION_MODEL=gpt-4o

# --- Embeddings (opcional) ---
EMBEDDING_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# --- RAG (opcional) ---
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVER_K=6

# --- Server (opcional) ---
HOST=0.0.0.0
PORT=5000
MAX_UPLOAD_SIZE_MB=50
